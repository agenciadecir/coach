# ===========================================
# CONFIGURACIÓN PARA VERCEL + SUPABASE
# ===========================================
# Copia este archivo a .env.local y completa los valores

# Base de datos Supabase (PostgreSQL)
# Obtén estos valores de: Supabase Dashboard > Project Settings > Database
# Connection string (pooler) para serverless:
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Connection string directo para migraciones:
DIRECT_DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# NextAuth Configuration
# Genera un secret con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secret-super-seguro-aqui"
NEXTAUTH_URL="https://tu-dominio.vercel.app"

# Opcional: Si usas un dominio personalizado
# NEXTAUTH_URL="https://tudominio.com"
