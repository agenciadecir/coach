# ============================================
# CONFIGURACIÓN PARA SUPABASE + VERCEL
# ============================================

# Base de datos PostgreSQL (Supabase)
# =====================================
# 1. Ve a Supabase Dashboard > Project Settings > Database
# 2. Copia la "Connection string" (URI format)
# 3. Reemplaza [YOUR-PASSWORD] con tu contraseña de base de datos

# Connection pooling (para Vercel/serverless) - USA ESTE
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Direct connection (para migraciones)
DIRECT_DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# NextAuth Secret - REQUERIDO
# Genera uno nuevo con: openssl rand -base64 32
NEXTAUTH_SECRET=tu-clave-secreta-muy-larga-y-segura-minimo-32-caracteres

# NextAuth URL - REQUERIDO para producción
# URL de tu app en Vercel (SIN slash al final)
# Ejemplo: https://mi-app-fitness.vercel.app
NEXTAUTH_URL=https://tu-app.vercel.app

# ============================================
# INSTRUCCIONES DE CONFIGURACIÓN
# ============================================

# PASO 1: Crear proyecto en Supabase
# ----------------------------------
# 1. Ve a https://supabase.com y crea una cuenta
# 2. Crea un nuevo proyecto
# 3. Anota la contraseña que creas para la base de datos
# 4. Espera a que el proyecto esté listo (~2 minutos)

# PASO 2: Obtener strings de conexión
# ------------------------------------
# 1. Ve a Project Settings > Database
# 2. En "Connection string" > "URI" copia el string
# 3. Reemplaza [YOUR-PASSWORD] con tu contraseña
# 4. Usa el puerto 6543 para DATABASE_URL (pooling)
# 5. Usa el puerto 5432 para DIRECT_DATABASE_URL

# PASO 3: Configurar en Vercel
# -----------------------------
# Ve a tu proyecto en Vercel > Settings > Environment Variables
# Agrega estas variables:
# - DATABASE_URL (valor del pooling connection)
# - DIRECT_DATABASE_URL (valor del direct connection)
# - NEXTAUTH_SECRET (genera uno nuevo seguro)
# - NEXTAUTH_URL (tu URL de Vercel: https://tu-app.vercel.app)

# ============================================
# NOTAS IMPORTANTES
# ============================================
# - NUNCA subas el archivo .env a GitHub
# - Usa valores DIFERENTES para NEXTAUTH_SECRET en desarrollo y producción
# - DATABASE_URL usa puerto 6543 (connection pooling para serverless)
# - DIRECT_DATABASE_URL usa puerto 5432 (para migraciones Prisma)
